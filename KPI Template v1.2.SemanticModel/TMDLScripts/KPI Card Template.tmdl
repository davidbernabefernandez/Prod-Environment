createOrReplace

	table 'Dummy Fact Table'
		lineageTag: e8237415-6e7c-4ab9-9cb1-3e70eb20012f

		measure 'KPI Card - Example Chart Title' = ```
				
				"Example of a 
				Card Title"
				--If you need to use 2 lines, you can follow the format above -- otherwise we don't need a measure
				```
			displayFolder: 01. KPI Card Measures
			lineageTag: 11826e8a-77b4-4654-a173-dce22967e69a

		measure 'KPI Card - Example Measure (Text Arrow Card)' = ```
				
				 
				var measure_evaluated = [KPI Card - Example Measure vs Target]
				// var measure_evaluated_text = [LCR (Text)]
				
				VAR measure_evaluated_text = CONCATENATE(
				    CONCATENATE(
				        CONCATENATE( FORMAT([KPI Card - Example Measure vs Target], "0"), " ("), -- we use pp because we are comparing percentages. The format varies
				        FORMAT([KPI Card - Example Measure vs Target (%)], "0%")
				    ),
				    ")"
				)
				 
				RETURN
				SWITCH(
				    TRUE()
				    ,measure_evaluated > 0, "▲ "&measure_evaluated_text --this changes if increase is bad, depends on the comparison
				    ,measure_evaluated < 0, "▼ "&measure_evaluated_text -- the colors would also invert if that's the case
				    ,measure_evaluated = 0, measure_evaluated_text
				) &" vs Target" -- this will depend on the comparison
				```
			displayFolder: 01. KPI Card Measures
			lineageTag: cb1917b8-7187-491c-89c8-33bb264b5b8c

		measure 'KPI Card - Example Measure AC' = SUM('Dummy Fact Table'[example_value])
			formatString: #,0.00%;-#,0.00%;#,0.00%
			displayFolder: 01. KPI Card Measures
			lineageTag: 0455da4c-e0ca-4d2d-93f1-6bc152f608c8

		measure 'KPI Card - Example Measure AC Date (Last Date Available)' = MAX('Dummy Fact Table'[Date])
			formatString: General Date
			displayFolder: 01. KPI Card Measures
			lineageTag: 99858d9d-1d18-4bbe-8217-b5f7725b12ec

		measure 'KPI Card - Example Measure AC Value (Last Date Available)' = CALCULATE(SUM('Dummy Fact Table'[example_value]), LASTDATE('Dummy Fact Table'[Date]))
			formatString: 0\ %;-0\ %;0\ %
			displayFolder: 01. KPI Card Measures
			lineageTag: 25825004-7841-46a2-9784-f7e027e65e21

		measure 'KPI Card - Example Measure FC' =
				
				--- This is just made up for the sake of the visual
				IF(ISBLANK([KPI Card - Example Measure AC]),BLANK(),[KPI Card - Example Measure AC] - 0.5)
			formatString: 0%;-0%;0%
			displayFolder: 01. KPI Card Measures
			lineageTag: 6e7eff0a-049a-4512-8b64-fd12c99ec869

		measure 'KPI Card - Example Measure vs Target' = ([KPI Card - Example Measure AC Value (Last Date Available)] - [KPI Card - Target 1 (100%)])*100
			formatString: 0
			displayFolder: 01. KPI Card Measures
			lineageTag: daefc6f8-eae0-467a-a3fb-cff03f12ccb6

		measure 'KPI Card - Example Measure vs Target (%)' = ```
				
				 DIVIDE(
				    [KPI Card - Example Measure AC Value (Last Date Available)],
				    [KPI Card - Target 1 (100%)]
				 ) - 1
				```
			formatString: 0.00\ %;-0.00\ %;0.00\ %
			displayFolder: 01. KPI Card Measures
			lineageTag: 05d23a81-e73c-4dab-85ee-5616a188f04d

		measure 'KPI Card - Target 1 (100%)' = ```
				1 --Target has been defined as 100% 
				--We can add it as it is, or as a new Measure if we want it to appear in the legend instead of with a label.
				```
			formatString: 0%;-0%;0%
			displayFolder: 01. KPI Card Measures
			lineageTag: 6ac80e99-54d1-4d56-a74a-93c3c52bcaf7

		measure 'KPI Card - Target 2 (150%)' = 1.5 --Target has been defined as 150%
			formatString: 0%;-0%;0%
			displayFolder: 01. KPI Card Measures
			lineageTag: e215c6e0-d0a9-4caa-a5ff-5ee8e817f625

