		partition 'Dummy Fact Table' = m
			mode: import
			source =
					let
					    Source = Table.FromRows(Json.Document(Binary.Decompress(Binary.FromText("", BinaryEncoding.Base64), Compression.Deflate)), let _t = ((type nullable text) meta [Serialized.Text = true]) in type table [Date = _t, example_value = _t, Organization = _t]),
					    #"Changed Type" = Table.TransformColumnTypes(Source,{{"Date", type date},{"example_value", type number}})
					in
					    #"Changed Type"

		annotation PBI_NavigationStepName = Navigation

		annotation PBI_ResultType = Table

