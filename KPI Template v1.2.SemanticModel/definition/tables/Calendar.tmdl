	partition Calendar = m
		mode: import
		source =
				let
				    // Connect to Databricks source
				    Source = Databricks.Catalogs("adb-6136409691618522.2.azuredatabricks.net", "/sql/1.0/warehouses/f8b9c3ff19c098c8", [Catalog=null, Database=null, QueryTags=null, EnableAutomaticProxyDiscovery=null, Implementation=null]),
				
				    // Load the calendar_farcaster table
				    calendar_farcaster = Source{[Name="ax_prod_gold",Kind="Database"]}[Data]
				                             {[Name="reference_calendar_mta",Kind="Schema"]}[Data]
				                             {[Name="calendar_mta",Kind="Table"]}[Data],
				
				    // Load the metadata table (calendar_column_mapping)
				    calendar_column_mapping = Source{[Name="ax_dev_gold",Kind="Database"]}[Data]
				                                {[Name="reference_calendar_mta",Kind="Schema"]}[Data]
				                                {[Name="calendar_mta_colname_mapping",Kind="Table"]}[Data],
				
				    // Create the rename-list from the metadata table
				    RenameList = Table.ToRows(
				                    Table.SelectColumns(
				                        calendar_column_mapping, {"technical_name", "alias_en"}
				                    )
				                 ),
				
				    // Dynamically rename columns based on metadata
				    RenamedColumns = Table.RenameColumns(calendar_farcaster, RenameList, MissingField.Ignore)
				in
				    RenamedColumns

