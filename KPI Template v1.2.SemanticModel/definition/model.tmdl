model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-GB
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation __PBI_TimeIntelligenceEnabled = 0

annotation PBI_QueryOrder = ["Dummy Fact Table","@Measures","Calendar","Refresh Time","Query1"]

annotation PBI_ProTooling = ["TMDLView_Desktop","DevMode"]

ref table 'Dummy Fact Table'
ref table LDA
ref table @Measures
ref table Calendar
ref table 'Refresh Time'
ref table Query1

ref cultureInfo en-US

